# ==============================================================================
# DATABASE CONFIGURATION (Supabase PostgreSQL)
# ==============================================================================

# DATABASE_URL - PostgreSQL connection string for Prisma Client (Transaction Mode)
# Uses connection pooling via Supabase Pooler on port 6543 for optimal performance
# Required for all database operations in the application
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true
# Get from: Supabase Dashboard → Project Settings → Database → Connection String (Transaction Mode)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL - PostgreSQL connection string for Prisma Migrations (Session Mode)
# Direct connection on port 5432 without connection pooling
# Required by Prisma for running migrations and schema operations
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@[HOST]:5432/postgres
# Get from: Supabase Dashboard → Project Settings → Database → Connection String (Session Mode)
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# ==============================================================================
# SUPABASE AUTHENTICATION
# ==============================================================================

# NEXT_PUBLIC_SUPABASE_URL - Your Supabase project URL
# Public variable exposed to the browser for client-side Supabase operations
# Used for authentication (magic links) and client-side database queries
# Format: https://[PROJECT-REF].supabase.co
# Get from: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=""

# NEXT_PUBLIC_SUPABASE_ANON_KEY - Supabase anonymous/public API key
# Public variable exposed to the browser for client-side authentication
# Safe to expose as it respects Row Level Security (RLS) policies
# Used for passwordless magic link authentication
# Get from: Supabase Dashboard → Project Settings → API → Project API keys → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# SUPABASE_SERVICE_ROLE_KEY - Supabase service role key (server-side only)
# Secret key with full database access, bypasses RLS policies
# Used for admin operations and server-side API routes
# ⚠️ NEVER expose this to the client or commit to version control
# Get from: Supabase Dashboard → Project Settings → API → Project API keys → service_role
SUPABASE_SERVICE_ROLE_KEY=""

# ==============================================================================
# EMAIL NOTIFICATIONS (SendGrid)
# ==============================================================================

# SENDGRID_API_KEY - SendGrid API key for sending transactional emails
# Used to send invitation emails, leave request notifications, and approval/denial emails
# Required for all email functionality in the application
# Get from: SendGrid Dashboard → Settings → API Keys → Create API Key
# Permissions needed: Mail Send (Full Access)
SENDGRID_API_KEY=""

# SENDGRID_FROM_EMAIL - Verified sender email address for outgoing emails
# Must be a verified sender identity in your SendGrid account
# Used as the "From" address for all system emails
# Format: noreply@yourdomain.com or notifications@yourdomain.com
# Setup: SendGrid Dashboard → Settings → Sender Authentication → Verify Single Sender
SENDGRID_FROM_EMAIL="noreply@yourdomain.com"

# ==============================================================================
# ADMIN ACCOUNT SEEDING
# ==============================================================================

# ADMIN_EMAIL - Email address for the initial admin account
# Used by the seed script (prisma/seed.ts) to create the first admin profile
# This user will have full admin privileges and can invite other users
# Must match the email you'll use to log in for the first time
# Run: npm run prisma:seed to create the admin account
ADMIN_EMAIL="admin@yourdomain.com"

# ADMIN_NAME - Full name for the initial admin account
# Display name shown in the UI for the admin user
# Used by the seed script when creating the first admin profile
ADMIN_NAME="System Administrator"

# ==============================================================================
# APPLICATION CONFIGURATION
# ==============================================================================

# NEXT_PUBLIC_APP_URL - Base URL of your application
# Used in email templates for magic link redirects and invitation links
# Set to http://localhost:3000 for local development
# Set to your production domain for deployment (e.g., https://yourdomain.com)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
