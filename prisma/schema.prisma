generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Employee {
  id              Int            @id @default(autoincrement())
  name            String
  email           String         @unique
  daysCarryOver   Int            // Old days (Expiring June 30)
  daysCurrentYear Int            // New days
  isActive        Boolean        @default(true) // Soft delete
  requests        LeaveRequest[]
}

model LeaveRequest {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  startDate  DateTime
  endDate    DateTime
  daysCount  Int
  status     String   // "REQUESTED", "APPROVED", "DENIED"
  createdAt  DateTime @default(now())
}
